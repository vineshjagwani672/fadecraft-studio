# ============ FRONTEND (Vite) ============
# Optional: if API is on another domain in production (no trailing slash)
# VITE_API_BASE=https://your-vercel-app.vercel.app

# Same random string as NOTIFY_SECRET below — stops random people spamming your API
VITE_NOTIFY_SECRET=your-secret-key-here

# ============ BACKEND API (Serverless on Vercel) ============
# MySQL Database Configuration
DB_HOST=your-mysql-host
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=fadecraft_db
DB_PORT=3306

# CORS Settings
CORS_ORIGIN=https://your-vercel-app.vercel.app

# ============ NOTIFY SERVER (Optional - Render.com) ============
# Email (SMTP) settings for sending booking notifications

# Example (Gmail app password):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_USER=youremail@gmail.com
# EMAIL_PASS=your-app-password

# Destination (where booking notifications are sent):
EMAIL_TO=vineshjagwani672@gmail.com

# Must match VITE_NOTIFY_SECRET
NOTIFY_SECRET=your-secret-key-here

PORT=8787

# Comma-separated dev origins (production: your real site URL)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
