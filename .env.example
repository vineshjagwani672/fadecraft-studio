# ============ FRONTEND (Vite) ============
# Optional: manual WhatsApp link on success (digits only, e.g. 923001234567)
VITE_WHATSAPP_NUMBER=

# Optional: if API is on another domain in production (no trailing slash)
# VITE_API_BASE=https://api.yourdomain.com

# Same random string as NOTIFY_SECRET below — stops random people spamming your API
VITE_NOTIFY_SECRET=

# Set to 1 to skip auto-notify calls (e.g. static hosting without backend)
# VITE_DISABLE_NOTIFY=1

# ============ NOTIFY SERVER (Node) ============
# Copy this file to ".env" in the project root and fill values.

# CallMeBot (free): add bot +34 623 78 64 49, WhatsApp "I allow callmebot to send me messages", paste API key:
CALLMEBOT_API_KEY=

# Your WhatsApp (international, with +) — same number you used to activate CallMeBot
CALLMEBOT_PHONE=+923001234567

# Must match VITE_NOTIFY_SECRET if you set it
NOTIFY_SECRET=

PORT=8787

# Comma-separated dev origins (production: your real site URL)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
